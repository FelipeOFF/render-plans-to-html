{
  "name": "render-plans-to-html",
  "version": "0.1.1",
  "description": "Tool-agnostic renderer that turns Markdown plans/specs/reviews into a single self-contained interactive HTML dashboard. Available as a skill for Claude Code and Codex.",
  "type": "module",
  "bin": {
    "render-plans-to-html": "./bin/render-plans.js",
    "render-plans": "./bin/render-plans.js",
    "render-plans-to-html-install": "./bin/install.js"
  },
  "files": [
    "bin/",
    "src/",
    "skill/SKILL.md",
    "README.md",
    "README.pt-BR.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "skill:install": "node bin/install.js"
  },
  "keywords": [
    "claude-code",
    "codex",
    "skill",
    "markdown",
    "html",
    "renderer",
    "plan",
    "spec",
    "review",
    "mermaid"
  ],
  "homepage": "https://github.com/FelipeOFF/render-plans-to-html",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FelipeOFF/render-plans-to-html.git"
  },
  "bugs": {
    "url": "https://github.com/FelipeOFF/render-plans-to-html/issues"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "marked": "^14.1.3"
  },
  "devDependencies": {
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
